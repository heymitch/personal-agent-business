# ============================================================================
# personal-agent-business .env -- copy this file to .env and fill it in.
# .env is GITIGNORED. Never commit .env.
#
# These are the OPERATOR keys: the accounts YOU use to stand up your own
# always-on personal agent, deploy your selling surfaces, and mint a personal
# agent for each client on demand. The cockpit reads these, sets them where
# they belong, and reports "set / works" -- it never prints a key back to you.
# ============================================================================

# --- Hetzner (creates the always-on cloud boxes: yours + each client's) ----
# Hetzner Cloud > Security > API Tokens > Generate (Read & Write).
HETZNER_TOKEN=

# Short, lowercase name for YOUR own always-on agent (e.g. mitch or kai). Becomes
# the box name and the Cloudflare host. Each client agent is named separately at
# mint time as <person-slug>-<account-slug>; this is only your own tracer box.
AGENT_NAME=

# Public SSH key the boxes will trust for root login. Leave blank to auto-detect
# ~/.ssh/id_ed25519.pub then ~/.ssh/id_rsa.pub. Paste the .pub CONTENTS to override.
SSH_PUBKEY=

# Path to the PRIVATE SSH key whose .pub you put in SSH_PUBKEY (e.g.
# ~/.ssh/id_ed25519). Used as ssh -i <SSH_KEY> to reach the box. Leave blank to
# let SSH use your default agent/identity.
SSH_KEY=

# --- Agent brain (the model that thinks) ----------------------------------
# Provider is openai-api with an EXPLICIT base_url (an admin key cannot infer
# the endpoint). The factory uses the admin key to mint a per-person brain key
# for each client agent. OpenRouter is OpenAI-API-compatible.
# OpenAI admin (or OpenRouter) key with permission to create sub-keys.
OPENAI_ADMIN_KEY=
# Per-agent brain key for YOUR own box (OpenRouter or OpenAI). Optional: leave
# blank to bring the box up brain-less and connect a model by OAuth in the
# dashboard (Providers > connect) after provisioning.
OPENAI_API_KEY=
# Explicit provider endpoint. OpenRouter shown; set your provider's if different.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Model id your provider exposes (OpenRouter example shown).
BRAIN_MODEL=openai/gpt-5.5

# --- AgentMail (OPTIONAL: give the agent its OWN inbox) -------------------
# OPTIONAL. AgentMail is the agent's own dedicated inbox (send/receive on its
# behalf). Skip BOTH keys if your agent uses Gmail through Composio instead.
# AgentMail dashboard > API Keys.
AGENTMAIL_API_KEY=
# OPTIONAL. The inbox address the agent sends and receives from (e.g.
# you@agentmail.to). Leave blank if you are not using AgentMail.
AGENTMAIL_INBOX=

# --- Composio (per-person tool binding for each client agent) -------------
# Your operator Composio API key (Composio dashboard > Settings > API Keys).
# The factory binds each client's own apps to their agent through Composio.
COMPOSIO_API_KEY=

# --- Onboarding surface (the client connect page) -------------------------
# Public base URL of your deployed onboarding surface. Set automatically by
# deploy_surfaces.sh after the first deploy -- you do not need to type this.
# Used to build each client's /?user=<id> connect link.
ONBOARDER_BASE_URL=

# Address clients are invited to join Slack from (your ops inbox).
# Set your own -- this is just a placeholder.
SLACK_INVITE_ADDRESS=ops@your-domain.com

# --- Cloudflare (public, login-gated web address per client) --------------
# Cloudflare > My Profile > API Tokens. Needs: Zone:Read, DNS:Edit,
# Account:Cloudflare Tunnel:Edit, Account:Access:Apps and Policies:Edit.
CLOUDFLARE_API_TOKEN=
# Cloudflare dashboard > any domain > right sidebar "Account ID".
CLOUDFLARE_ACCOUNT_ID=
# The operator domain you added to Cloudflare (e.g. my-agents.com). Each client
# agent lives at <person-slug>-<account-slug>.<AGENT_DOMAIN>.
AGENT_DOMAIN=
# The email allowed through the login gate (one-time PIN to this address).
OWNER_EMAIL=

# --- Vercel (deploy the console + onboarding + landing surfaces) ----------
# No token. Vercel auth is a Claude Code connection: run `vercel login` once and
# the persisted CLI session deploys your surfaces. deploy_surfaces.sh uses that
# logged-in session and passes no --token flag.
# OPTIONAL. Your Vercel account/team (org) id, from Vercel > Settings > General.
# Only needed to scope deploys to a specific team; leave blank otherwise.
VERCEL_ORG_ID=

# --- Console + receiver wiring (set AFTER the engine + the console gate) ----
# The operator console is a thin proxy to your box receiver, gated by Cloudflare
# Access (the SAME email gate as your client surfaces). You do NOT type these up
# front; the cockpit captures them once the engine is deployed and the gate is
# created, then sets them into the console's Vercel env.
# The box receiver URL the console proxies to (deploy_engine.sh prints RECEIVER-URL).
MINT_RECEIVER_URL=
# Shared secret the console presents to the receiver (sent as x-sim-secret). Use any
# strong random string; it must match the receiver's SIM_SECRET on the box.
MINT_SECRET=
# Your Cloudflare Access team auth domain, e.g. my-team.cloudflareaccess.com
# (cf_console_gate.sh prints CF_ACCESS_AUTH_DOMAIN). Gates the console to OWNER_EMAIL.
CF_ACCESS_AUTH_DOMAIN=
# The console Access app's Audience (AUD) tag (cf_console_gate.sh prints CF_ACCESS_AUD).
CF_ACCESS_AUD=
# The console's gated hostname (defaults to console.<AGENT_DOMAIN>). Leave blank for
# the default.
CONSOLE_HOST=

# --- Default skills (what every new client agent ships with) ---------------
# Comma-separated capability ids that EVERY newly minted client agent ships with by
# default. The New-agent picker pre-checks them and the mint applies them as a floor
# even if the picker is left empty. Pick from your operator skills, e.g.
# repurpose,sales-followup. Leave blank for no defaults.
DEFAULT_SKILLS=

# --- Slack (talk to your operator agent) ----------------------------------
# From your Slack app: OAuth & Permissions (bot token) + App-Level Token.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Your Slack member ID (Profile > More > Copy member ID). Pre-approves you so
# you skip the pairing-code prompt.
SLACK_ALLOWED_USERS=

# --- Ongoing maintenance (the two DAILY timers on your box) ---------------
# Daily git backup of your agency state (config / mint registry / skills). The
# git-backup timer commits + pushes here every day. Your .env and key material
# are NEVER pushed. Use a PRIVATE repo. A token in the URL is fine -- it stays on
# your box's own env file and is never printed.
#   e.g. https://x-access-token:<PAT>@github.com/you/agency-backup.git
BACKUP_GIT_REMOTE=
# Branch the backup pushes to (default: main). Leave blank for main.
BACKUP_GIT_BRANCH=
# Optional fleet fan-out for the daily Hermes self-update: set to 1 to also run
# `hermes update` on each client box in your mint registry. Off (0) by default.
UPDATE_FLEET=0
