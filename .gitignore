# Secrets -- NEVER commit. The only home for keys on the operator's machine.
.env
.env.local
*.pem
*.key
id_ed25519*

# Node / build artifacts (vendored installer + surfaces land in later slices)
node_modules/
dist/
build/
.vercel/

# Local runtime / logs
*.log
.DS_Store

# receiver / engine runtime state (the box writes these; never commit)
installer/receiver/session-store*.json
installer/receiver/checkout-queue.jsonl

# agentize skill-packaging staging dir (operator's packaged skill bundles)
.agentize-staging/

# operator's real agent profiles (their OWN skill ids). Ship only the neutral
# config/agent-profiles.example.json; never the operator's filled-in copy.
config/agent-profiles.json

# bats temp -- ignore contents but keep the dir (tracked via .gitkeep)
test/tmp/*
!test/tmp/.gitkeep

# stray speakeasy hook artifact
build-log.md
